{
  "name": "veracode-create-teams-action",
  "description": "Automatically create and manage Veracode teams based on repository configurations",
  "version": "1.0.1",
  "author": "William Sanders",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/wsandersvc/veracode-create-teams-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsandersvc/veracode-create-teams-action.git"
  },
  "bugs": {
    "url": "https://github.com/wsandersvc/veracode-create-teams-action/issues"
  },
  "keywords": [
    "actions"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/github": "9.0.0",
    "axios": "1.15.0",
    "js-yaml": "4.1.1",
    "qs": "6.15.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.4",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@github/local-action": "7.0.1",
    "@jest/globals": "30.3.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.5.2",
    "@types/qs": "6.15.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "lodash": "4.18.1",
    "make-coverage-badge": "1.2.0",
    "picomatch": "2.3.2",
    "prettier": "3.8.1",
    "rollup": "4.57.1",
    "sjcl": "1.0.9",
    "ts-jest": "29.4.9",
    "ts-jest-resolver": "2.0.1",
    "typescript": "5.9.3",
    "undici": ">=6.24.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
